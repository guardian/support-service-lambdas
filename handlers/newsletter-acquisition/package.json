{
  "name": "newsletter-acquisition",
  "scripts": {
    "test": "jest --group=-integration",
    "it-test": "jest --group=integration",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --cache-location /tmp/eslintcache/ 'src/**/*.ts' 'test/**/*.ts'",
    "check-formatting": "prettier --check \"**/*.ts\"",
    "fix-formatting": "prettier --write \"**/*.ts\"",
    "build": "esbuild --bundle --platform=node --target=node22 --outdir=target/ src/index.ts --sourcemap --source-root=/support-service-lambdas/handlers/newsletter-acquisition/target/",
    "package": "pnpm buildcheck:all && pnpm type-check:all && pnpm lint:all && pnpm check-formatting:all && pnpm test:all && pnpm build && cd target && zip -qr newsletter-acquisition.zip ./*.js.map ./*.js",
    "cdk:test": "pnpm --filter cdk test newsletter-acquisition",
    "cdk:test-update": "pnpm --filter cdk test-update newsletter-acquisition",
    "update-lambda": "../../update-lambda.sh \"newsletter-acquisition\"",
    "update-stack": "../../update-stack.sh \"newsletter-acquisition\"",
    "buildcheck": "pnpm --filter buildcheck snapshot:assert handlers/newsletter-acquisition",
    "buildcheck:all": "pnpm --filter newsletter-acquisition buildcheck && pnpm buildcheck",
    "type-check:all": "pnpm --filter newsletter-acquisition type-check && pnpm type-check",
    "lint:all": "pnpm --filter newsletter-acquisition lint && pnpm lint",
    "check-formatting:all": "pnpm --filter newsletter-acquisition check-formatting && pnpm check-formatting",
    "test:all": "pnpm --filter newsletter-acquisition test && pnpm test"
  },
  "NOTICE1": "MANAGED FILE: to push changes see buildcheck/README.md - template: buildcheck/data/templates/handler/package.json.ts",
  "NOTICE2": "all dependencies are defined in buildcheck/data/build.ts",
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.940.0",
    "@aws-sdk/util-dynamodb": "^3.940.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147"
  }
}
