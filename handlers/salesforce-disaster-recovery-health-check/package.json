{
  "name": "salesforce-disaster-recovery-health-check",
  "scripts": {
    "test": "jest --group=-integration",
    "it-test": "jest --group=integration",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --cache-location /tmp/eslintcache/ 'src/**/*.ts' 'test/**/*.ts'",
    "check-formatting": "prettier --check \"**/*.ts\"",
    "fix-formatting": "prettier --write \"**/*.ts\"",
    "build": "esbuild --bundle --platform=node --target=node22 --outdir=target/ src/handlers/*.ts --sourcemap --source-root=/support-service-lambdas/handlers/salesforce-disaster-recovery-health-check/target/",
    "package": "pnpm buildcheck:all && pnpm type-check:all && pnpm lint:all && pnpm check-formatting:all && pnpm test:all && pnpm build && cd target && zip -qr salesforce-disaster-recovery-health-check.zip ./*.js.map ./*.js",
    "cdk:test": "pnpm --filter cdk test salesforce-disaster-recovery-health-check",
    "cdk:test-update": "pnpm --filter cdk test-update salesforce-disaster-recovery-health-check",
    "update-lambda": "../../update-lambda.sh \"salesforce-disaster-recovery-health-check\" salesforce-disaster-recovery-health-check-",
    "update-stack": "../../update-stack.sh \"salesforce-disaster-recovery-health-check\"",
    "buildcheck": "pnpm --filter buildcheck snapshot:assert handlers/salesforce-disaster-recovery-health-check",
    "buildcheck:all": "pnpm --filter salesforce-disaster-recovery-health-check buildcheck && pnpm buildcheck",
    "type-check:all": "pnpm --filter salesforce-disaster-recovery-health-check type-check && pnpm type-check",
    "lint:all": "pnpm --filter salesforce-disaster-recovery-health-check lint && pnpm lint",
    "check-formatting:all": "pnpm --filter salesforce-disaster-recovery-health-check check-formatting && pnpm check-formatting",
    "test:all": "pnpm --filter salesforce-disaster-recovery-health-check test && pnpm test"
  },
  "NOTICE1": "MANAGED FILE: to push changes see buildcheck/README.md - template: buildcheck/data/templates/handler/package.json.ts",
  "NOTICE2": "all dependencies are defined in buildcheck/data/build.ts",
  "dependencies": {
    "@aws-sdk/client-sfn": "^3.940.0",
    "@aws-sdk/client-sns": "^3.940.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.147"
  }
}
