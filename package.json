{
	"name": "@guardian/support-service-lambdas",
	"version": "1.0.0",
	"scripts": {
		"build": "pnpm --stream -r run build",
		"package": "pnpm --stream -r run package",
		"type-check": "pnpm --stream -r run type-check",
		"lint": "pnpm --stream -r run lint",
		"clean": "rm -rf .parcel-cache && pnpm -r run clean",
		"test": "pnpm --stream -r run test",
		"it-test": "pnpm --stream -r run it-test",
		"new-api-lambda": "pnpm hygen new-lambda api-gateway && pnpm snapshot:update && pnpm install && pnpm --filter cdk lint --fix && pnpm fix-formatting && pnpm --filter cdk test-update && git add .",
		"prepare": "husky",
		"fix-formatting": "pnpm -r run fix-formatting",
		"check-formatting": "pnpm -r run check-formatting",
		"validate": "pnpm -r run fix-formatting && pnpm -r run lint --fix && pnpm -r run type-check && pnpm -r run test",
		"snapshot:update": "cd buildcheck && pnpm run snapshot:update"
	},
	"devDependencies": {
		"eslint": "^9.38.0",
		"@guardian/eslint-config": "^11.0.0",
		"@guardian/prettier": "^8.0.1",
		"@types/jest": "^29.5.14",
		"@types/node": "^22.14.1",
		"esbuild": "^0.25.4",
		"globals": "^16.4.0",
		"husky": "^9.1.7",
		"hygen": "^6.2.11",
		"jest": "^29.7.0",
		"jest-runner-groups": "^2.2.0",
		"prettier": "^3.3.3",
		"ts-jest": "^29.4.11",
		"typescript": "catalog:",
		"@typescript/native": "catalog:",
		"zod": "catalog:"
	},
	"packageManager": "pnpm@11.13.0"
}
