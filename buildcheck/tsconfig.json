{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["es2020"],
    "baseUrl": ".",
    "paths": {
      "@buildcheck/types": ["data/types.ts"]
    },
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "test/**/*", "data/**/*"],
  "exclude": ["node_modules", "dist"]
}