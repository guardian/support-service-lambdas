{
	"name": "buildcheck",
	"version": "1.0.0",
	"private": true,
	"description": "Build file generator for handlers",
	"scripts": {
		"snapshot:update": "pnpm generate && REPO_ROOT=\"$(pwd | sed 's|/buildcheck.*||')\" && tsx src/cli.ts \"$REPO_ROOT\" --generate",
		"snapshot:clean": "pnpm generate && REPO_ROOT=\"$(pwd | sed 's|/buildcheck.*||')\" && tsx src/cli.ts \"$REPO_ROOT\" --clean",
		"seed": "pnpm generate && REPO_ROOT=\"$(pwd | sed 's|/buildcheck.*||')\" && tsx src/cli.ts \"$REPO_ROOT\" --seed \"$@\"",
		"snapshot:assert": "pnpm generate && REPO_ROOT=\"$(pwd | sed 's|/buildcheck.*||')\" && bash -c 'jest --testNamePattern=\"$*\"' -- \"$@\"",
		"clean": "rm -rf src/dynamic/generated dist",
		"generate": "bash src/dynamic/generate-template-list.sh",
		"test": "pnpm generate && jest",
		"type-check": "pnpm generate && tsc --noEmit",
		"lint": "pnpm generate && eslint 'src/**/*.ts' 'test/**/*.ts' 'data/**/*.ts'",
		"check-formatting": "pnpm generate && prettier --check \"**/*.ts\"",
		"fix-formatting": "pnpm generate && prettier --write \"**/*.ts\""
	},
	"dependencies": {
		"js-yaml": "^4.1.1"
	},
	"devDependencies": {
		"@jest/globals": "^30.0.4",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^22.15.14",
		"tsx": "^4.21.0",
		"typescript": "^5.0.0"
	}
}
