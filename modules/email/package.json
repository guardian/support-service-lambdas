{
  "name": "email",
  "scripts": {
    "test": "jest --group=-integration",
    "it-test": "NODE_OPTIONS=\"$NODE_OPTIONS --experimental-vm-modules\" jest --group=integration",
    "type-check": "tsc --noEmit",
    "lint": "eslint --cache --cache-location /tmp/eslintcache/ 'src/**/*.ts' 'test/**/*.ts'",
    "lint-fix": "eslint --cache --cache-location /tmp/eslintcache/ --fix 'src/**/*.ts' 'test/**/*.ts'",
    "check-formatting": "prettier --check \"**/*.ts\"",
    "fix-formatting": "prettier --write \"**/*.ts\"",
    "build": "tsc --noEmit"
  },
  "NOTICE1": "MANAGED FILE: to push changes see buildcheck/README.md - template: buildcheck/data/templates/module/package.json.ts",
  "NOTICE2": "all dependencies are defined in buildcheck/data/build.ts",
  "dependencies": {
    "@aws-sdk/client-sqs": "^3.940.0",
    "dayjs": "^1.11.13",
    "aws": "workspace:*",
    "internationalisation": "workspace:*",
    "product-catalog": "workspace:*"
  }
}
